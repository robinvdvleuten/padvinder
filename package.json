{
	"name": "padvinder",
	"version": "0.2.0",
	"description": "Tiny, CSP-safe, zero-dependency RFC 9535 JSONPath engine. No eval, no new Function.",
	"repository": "robinvdvleuten/padvinder",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "3 kB"
		},
		{
			"path": "dist/index.cjs",
			"limit": "3 kB"
		}
	],
	"scripts": {
		"build": "tsdown",
		"cts:update": "curl -sL -o test/cts.json https://raw.githubusercontent.com/jsonpath-standard/jsonpath-compliance-test-suite/main/cts.json && curl -sL -o test/cts.LICENSE https://raw.githubusercontent.com/jsonpath-standard/jsonpath-compliance-test-suite/main/LICENSE",
		"prepublishOnly": "npm run build",
		"size": "size-limit",
		"test": "node --disallow-code-generation-from-strings node_modules/tape/bin/tape test/*.test.js"
	},
	"keywords": [
		"jsonpath",
		"json",
		"query",
		"csp",
		"rfc9535"
	],
	"devDependencies": {
		"@size-limit/file": "^12.1.0",
		"size-limit": "^12.1.0",
		"tape": "^5.9.0",
		"tsdown": "^0.22.12"
	}
}
