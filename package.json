{
	"name": "padvinder",
	"version": "0.3.0",
	"description": "Tiny, CSP-safe RFC 9535 JSONPath engine. No eval, no new Function.",
	"repository": "robinvdvleuten/padvinder",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "3.5 kB"
		},
		{
			"path": "dist/index.cjs",
			"limit": "3.5 kB"
		}
	],
	"scripts": {
		"bench": "node --disallow-code-generation-from-strings bench/index.js",
		"bench:comparison": "npm run build && npm --prefix bench/comparison run bench",
		"build": "tsdown",
		"check": "run-s build size test fuzz:regression test:browser",
		"cts:update": "curl -sL -o test/cts.json https://raw.githubusercontent.com/jsonpath-standard/jsonpath-compliance-test-suite/main/cts.json && curl -sL -o test/cts.LICENSE https://raw.githubusercontent.com/jsonpath-standard/jsonpath-compliance-test-suite/main/LICENSE",
		"fuzz": "npm run fuzz:prepare && run-s fuzz:compile fuzz:find fuzz:structured",
		"fuzz:prepare": "node -e \"for (const x of ['compile','find','structured']) require('fs').mkdirSync('.fuzz-corpus/'+x,{recursive:true})\"",
		"fuzz:compile": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/compile.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync .fuzz-corpus/compile fuzz/corpus/compile -- -max_total_time=60 -timeout=25 -use_value_profile=1 -dict=fuzz/padvinder.dict -artifact_prefix=fuzz/",
		"fuzz:find": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/find.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync .fuzz-corpus/find fuzz/corpus/find -- -max_total_time=60 -timeout=25 -use_value_profile=1 -dict=fuzz/padvinder.dict -artifact_prefix=fuzz/",
		"fuzz:structured": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/structured.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync .fuzz-corpus/structured fuzz/corpus/structured -- -max_total_time=60 -timeout=25 -use_value_profile=1 -dict=fuzz/padvinder.dict -artifact_prefix=fuzz/",
		"fuzz:regression": "run-s fuzz:regression:compile fuzz:regression:find fuzz:regression:structured",
		"fuzz:regression:compile": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/compile.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync --mode=regression fuzz/corpus/compile -- -timeout=25 -artifact_prefix=fuzz/",
		"fuzz:regression:find": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/find.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync --mode=regression fuzz/corpus/find -- -timeout=25 -artifact_prefix=fuzz/",
		"fuzz:regression:structured": "NODE_OPTIONS=--disallow-code-generation-from-strings jazzer fuzz/structured.fuzz.js -i src/ --customHooks fuzz/hooks.js --disableBugDetectors='command-injection|path-traversal' --sync --mode=regression fuzz/corpus/structured -- -timeout=25 -artifact_prefix=fuzz/",
		"prepublishOnly": "npm run build",
		"size": "size-limit",
		"test": "run-s test:unit test:types",
		"test:unit": "node --disallow-code-generation-from-strings --test --test-concurrency=1 test/*.test.js",
		"test:browser": "npm run build && playwright install chromium && node test/browser/harness.js",
		"test:types": "tsc"
	},
	"keywords": [
		"jsonpath",
		"json",
		"query",
		"csp",
		"rfc9535"
	],
	"dependencies": {
		"treffer": "^0.2.0"
	},
	"devDependencies": {
		"@jazzer.js/bug-detectors": "^4.0.0",
		"@jazzer.js/core": "^4.0.0",
		"@size-limit/file": "^12.1.0",
		"npm-run-all": "^4.1.5",
		"playwright": "^1.61.1",
		"size-limit": "^12.1.0",
		"tsdown": "^0.22.12",
		"typescript": "^7.0.2"
	}
}
